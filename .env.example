# ==============================================================================
# Institutional AI Trading System - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ==============================================================================

# --- IG Trading Platform API ---
# Required: Your IG platform credentials
IG_API_KEY=your_ig_api_key
IG_USERNAME=your_ig_username
IG_PASSWORD=your_ig_password
IG_ACCOUNT_ID=your_ig_account_id
IG_ACCOUNT_TYPE=DEMO
IG_API_URL=https://demo-api.ig.com/gateway/deal
IG_STREAM_URL=https://demo-apd.marketdatasystems.com
AUTONOMOUS_STRATEGY=GUARDED_AUTO
PROFESSIONAL_STRATEGY_LIVE_APPROVED=false
PROFESSIONAL_STRATEGY_DEMO_FORWARD_APPROVED=false
NEWS_FILTER_MODE=FAIL_CLOSED
FMP_API_KEY=
MARKETAUX_API_KEY=
ENABLE_NEWS_FILTER=true
NEWS_CHECK_INTERVAL_MINUTES=10
NEWS_BLOCK_BEFORE_HIGH_IMPACT_MINUTES=30
NEWS_BLOCK_AFTER_HIGH_IMPACT_MINUTES=45
# Optional open-data geopolitical backup
ENABLE_GDELT_BACKUP=false

# --- Historical Market Data ---
# Optional: used by scripts/download_twelve_data_history.py
TWELVE_DATA_API_KEY=your_twelve_data_api_key
TWELVE_DATA_REQUEST_DELAY=0

# --- Database (PostgreSQL) ---
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://trading:trading_secret@localhost:5432/trading_system

# --- Redis ---
# Used for event bus, caching, and rate limiting
REDIS_URL=redis://localhost:6379/0

# --- JWT Authentication ---
# Secret key for signing JWT tokens (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=
# Access token expiration in minutes (default: 15)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token expiration in days (default: 7)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Risk Parameters ---
# Maximum risk per trade as fraction of account equity
MAX_RISK_PER_TRADE_PCT=0.02
# Maximum daily loss as fraction of equity (triggers kill switch)
MAX_DAILY_LOSS_PCT=0.03
# Maximum drawdown before kill switch activation
MAX_DRAWDOWN_PCT=0.15
# Maximum exposure per asset class
MAX_EXPOSURE_PER_CLASS_PCT=0.30
# Maximum total portfolio exposure
MAX_TOTAL_EXPOSURE_PCT=0.70

# --- HFT Configuration ---
# Enable/disable high-frequency trading pipeline
HFT_ENABLED=false
# Maximum total orders per second across all instruments
HFT_MAX_ORDER_RATE=100
# Maximum orders per second per instrument
HFT_MAX_PER_INSTRUMENT_RATE=50
# Batch window in milliseconds for order aggregation
HFT_BATCH_WINDOW_MS=100
# Maximum HFT trade size as fraction of equity
HFT_MAX_TRADE_SIZE_PCT=0.005
# Maximum total HFT exposure as fraction of equity
HFT_MAX_EXPOSURE_PCT=0.15

# --- News Engine API Keys ---
# Reuters news feed API key
NEWS_REUTERS_API_KEY=your_reuters_key
# Bloomberg B-PIPE API key
NEWS_BLOOMBERG_API_KEY=your_bloomberg_key
# Twitter/X API bearer token for social sentiment
NEWS_SOCIAL_MEDIA_BEARER_TOKEN=your_twitter_bearer_token
# Crisis detection threshold (number of correlated negative signals)
NEWS_CRISIS_THRESHOLD=3
# Sentiment threshold for negative classification
NEWS_SENTIMENT_THRESHOLD=-0.7

# --- Notifications - Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Notifications - Discord ---
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# --- Notifications - Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_TO_EMAIL=alerts@yourdomain.com

# --- ML Model Configuration ---
# Retrain interval in days
ML_RETRAIN_INTERVAL_DAYS=7
# Minimum accuracy threshold for model deployment
ML_MIN_ACCURACY_THRESHOLD=0.52

# --- Mistake Pattern Detection ---
# Number of losses with same classification to flag a pattern
MISTAKE_PATTERN_THRESHOLD=5
# Rolling window in days for pattern detection
MISTAKE_PATTERN_WINDOW_DAYS=30
# Consecutive profitable trades to resolve a pattern
MISTAKE_RESOLUTION_STREAK=20

# --- Application ---
# Environment: development, staging, production
APP_ENV=development
# Enable debug mode (disable in production)
APP_DEBUG=true
# Application secret key for session management
APP_SECRET_KEY=change_this_to_a_random_secret_key
# Host and port
APP_HOST=0.0.0.0
APP_PORT=8000

# --- TLS Configuration ---
# Path to CA certificate bundle (optional, uses system default if not set)
TLS_CA_BUNDLE_PATH=
# Minimum TLS version (1.2 or 1.3)
TLS_MIN_VERSION=1.2
# Enable certificate verification (always true in production)
TLS_VERIFY_CERTS=true

# --- Secrets Manager ---
# Backend: local, aws_ssm, aws_secrets_manager, vault
SECRETS_MANAGER_BACKEND=local
# AWS region (for AWS backends)
SECRETS_MANAGER_AWS_REGION=us-east-1
# Vault address (for HashiCorp Vault backend)
SECRETS_MANAGER_VAULT_ADDR=
SECRETS_MANAGER_VAULT_TOKEN=
# Rate limit: max secret accesses per minute
SECRETS_MANAGER_RATE_LIMIT=60
